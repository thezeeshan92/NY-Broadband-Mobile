<?xml version="1.0" encoding="utf-8"?>
<!--
    Test In Progress — premium dark speedometer UI.
    ConstraintLayout keeps the SpeedometerView as the clear focal point.
    All original view IDs are preserved for binding compatibility.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ds_bg"
    android:fitsSystemWindows="true">

    <!-- ── HEADER: logo + ISP name + close button ──────────────────────────── -->
    <LinearLayout
        android:id="@+id/headerRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@null"
            android:src="@mipmap/ic_launcher_round" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCarrierName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ds_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Verizon Wireless" />

            <TextView
                android:id="@+id/tvDeviceInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ds_text_muted"
                android:textSize="12sp"
                tools:text="Pixel 7 · Wi-Fi" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_ds_card_sm"
            android:contentDescription="@string/action_close"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            app:tint="@color/ds_text_secondary" />

    </LinearLayout>

    <!-- ── DL / UL GRADIENT BANNER (reduced height for less dominance) ───────── -->
    <LinearLayout
        android:id="@+id/bannerRow"
        android:layout_width="0dp"
        android:layout_height="76dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_speed_metric_banner"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/headerRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Download column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_download_24"
                app:tint="#CCFFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="@string/speed_download_mbps"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvDownloadResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="28.9" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBarDownload"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:indeterminate="false"
                android:progress="0"
                app:indicatorColor="#CCFFFFFF"
                app:trackColor="#33FFFFFF"
                app:trackCornerRadius="2dp"
                app:trackThickness="3dp" />
        </LinearLayout>

        <!-- Vertical divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="#33FFFFFF" />

        <!-- Upload column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_upload_24"
                app:tint="#CCFFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="@string/speed_upload_mbps"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvUploadResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="--" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBarUpload"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:indeterminate="false"
                android:progress="0"
                app:indicatorColor="#CCFFFFFF"
                app:trackColor="#33FFFFFF"
                app:trackCornerRadius="2dp"
                app:trackThickness="3dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── PING + DATA ROW ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="0dp"
        android:layout_height="30dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/bannerRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_schedule_24"
            app:tint="@color/ds_text_muted" />

        <TextView
            android:id="@+id/tvLatency"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:text="@string/speed_ping_placeholder"
            android:textColor="@color/ds_text_muted"
            android:textSize="12sp"
            tools:text="Ping 153 ms" />

        <ImageView
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_wifi_24"
            app:tint="@color/ds_text_muted" />

        <TextView
            android:id="@+id/tvDataUsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="@string/speed_data_placeholder"
            android:textColor="@color/ds_text_muted"
            android:textSize="12sp"
            tools:text="Data 40 MB" />

    </LinearLayout>

    <!-- ── OVERALL PROGRESS BAR: phone ─── bar ─── wifi ────────────────────── -->
    <LinearLayout
        android:id="@+id/progressRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="2dp"
        app:layout_constraintTop_toBottomOf="@id/statsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_cellular"
            app:tint="@color/ds_divider" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:indeterminate="false"
            android:progress="0"
            app:indicatorColor="@color/ds_accent"
            app:trackColor="@color/ds_divider"
            app:trackCornerRadius="3dp"
            app:trackThickness="4dp" />

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_wifi_24"
            app:tint="@color/ds_divider" />

    </LinearLayout>

    <!-- ── SPEEDOMETER (primary focal point — fills available space) ─────────── -->
    <com.nybroadband.mobile.presentation.test.SpeedometerView
        android:id="@+id/speedometerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/progressRow"
        app:layout_constraintBottom_toTopOf="@id/tvSpeedNumber"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_min="130dp"
        app:layout_constraintHeight_max="200dp"
        app:layout_constraintVertical_bias="0.0" />

    <!-- ── CURRENT SPEED NUMBER ──────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvSpeedNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="--"
        android:textColor="@color/ds_text_primary"
        android:textSize="54sp"
        android:textStyle="bold"
        android:includeFontPadding="false"
        android:letterSpacing="-0.02"
        app:layout_constraintBottom_toTopOf="@id/tvSpeedUnit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="44.08" />

    <!-- Speed unit label -->
    <TextView
        android:id="@+id/tvSpeedUnit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/test_speed_unit_mbps"
        android:textColor="@color/ds_text_secondary"
        android:textSize="14sp"
        android:letterSpacing="0.04"
        app:layout_constraintBottom_toTopOf="@id/tvPhaseLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Phase label -->
    <TextView
        android:id="@+id/tvPhaseLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/test_phase_starting"
        android:textColor="@color/ds_accent"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/phaseDotsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── PHASE DOTS ─────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/phaseDotsRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/contextTabsScroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/dotLatency"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/phase_dot"
            android:contentDescription="@string/test_phase_latency" />

        <View
            android:layout_width="28dp"
            android:layout_height="2dp"
            android:background="@color/ds_divider" />

        <TextView
            android:id="@+id/dotDownload"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/phase_dot"
            android:contentDescription="@string/test_phase_download" />

        <View
            android:layout_width="28dp"
            android:layout_height="2dp"
            android:background="@color/ds_divider" />

        <TextView
            android:id="@+id/dotUpload"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/phase_dot"
            android:contentDescription="@string/test_phase_upload" />

    </LinearLayout>

    <!-- hidden packet loss field — kept for binding compatibility -->
    <TextView
        android:id="@+id/tvPacketLoss"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="0.00%" />

    <!-- ── CONTEXT TABS (pill segmented control) ──────────────────────────────── -->
    <HorizontalScrollView
        android:id="@+id/contextTabsScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/locationRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/testTabIndoors"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_ds_tab_selected"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/speed_context_indoors"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/testTabOutdoors"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_ds_tab_unselected"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/speed_context_outdoors"
                android:textColor="@color/ds_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/testTabDriving"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_ds_tab_unselected"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/speed_context_driving"
                android:textColor="@color/ds_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/testTabOther"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_ds_tab_unselected"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/speed_context_other"
                android:textColor="@color/ds_text_secondary"
                android:textSize="13sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── LOCATION ROW ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/locationRow"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_ds_location_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@null"
            android:src="@drawable/flag_us_badge" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/speed_location_default"
            android:textColor="@color/ds_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/speed_location_change"
            android:textColor="@color/ds_accent"
            android:textSize="12sp" />

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="2dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_arrow_back"
            android:rotation="180"
            app:tint="@color/ds_accent" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
