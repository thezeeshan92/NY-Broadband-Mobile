<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/test_in_progress_title"
        app:titleTextColor="?attr/colorOnSurface" />

    <!-- Scrollable center content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/screen_margin"
            android:paddingTop="32dp">

            <!-- ── Phase step dots ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Latency dot -->
                <TextView
                    android:id="@+id/dotLatency"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/phase_dot"
                    android:contentDescription="@string/test_phase_latency" />

                <View
                    android:layout_width="28dp"
                    android:layout_height="1dp"
                    android:background="?attr/colorOutlineVariant" />

                <!-- Download dot -->
                <TextView
                    android:id="@+id/dotDownload"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/phase_dot"
                    android:contentDescription="@string/test_phase_download" />

                <View
                    android:layout_width="28dp"
                    android:layout_height="1dp"
                    android:background="?attr/colorOutlineVariant" />

                <!-- Upload dot -->
                <TextView
                    android:id="@+id/dotUpload"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/phase_dot"
                    android:contentDescription="@string/test_phase_upload" />

            </LinearLayout>

            <!-- Phase labels row (Latency | Download | Upload) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/test_phase_latency"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/test_phase_download"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/test_phase_upload"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- ── Big speed number ────────────────────────────────────────── -->
            <TextView
                android:id="@+id/tvPhaseLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:letterSpacing="0.06"
                android:text="@string/test_phase_starting"
                android:textAllCaps="true"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_label"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSpeedNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-light"
                android:text="--"
                android:textColor="?attr/colorOnSurface"
                android:textSize="64sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSpeedUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/test_speed_unit_mbps"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_body_small" />

            <!-- ── Progress bar ────────────────────────────────────────────── -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:indeterminate="true"
                app:indicatorColor="?attr/colorPrimary"
                app:trackColor="?attr/colorOutlineVariant"
                app:trackCornerRadius="4dp" />

            <!-- ── Live metrics row ───────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal">

                <!-- Download card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/colorSurfaceVariant"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvDownloadResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/test_phase_download"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp" />

                </LinearLayout>

                <View
                    android:layout_width="8dp"
                    android:layout_height="0dp" />

                <!-- Upload card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/colorSurfaceVariant"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvUploadResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/test_phase_upload"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp" />

                </LinearLayout>

                <View
                    android:layout_width="8dp"
                    android:layout_height="0dp" />

                <!-- Latency card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/colorSurfaceVariant"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvLatency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/test_speed_unit_latency"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Cancel link at the bottom ──────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/screen_margin"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tvCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingTop="12dp"
            android:paddingEnd="24dp"
            android:paddingBottom="12dp"
            android:text="@string/test_btn_cancel"
            android:textColor="?attr/colorError"
            android:textSize="@dimen/text_body" />

    </LinearLayout>

</LinearLayout>
