<?xml version="1.0" encoding="utf-8"?>
<!--
    Cellular Info screen – dark-themed to match the CoverageMap.com reference design.
    Content is built programmatically in CellularFragment to support any cell technology.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cellular_bg">

    <!-- App branding (matches reference: logo area + title) -->
    <TextView
        android:id="@+id/tvAppBranding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"
        android:text="@string/cellular_app_branding"
        android:textSize="@dimen/cellular_text_branding"
        android:textColor="@color/cellular_text_label" />

    <!-- ── Top header bar (help | carrier | settings — high-contrast icons) ─ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:background="@color/cellular_header_bg">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnHelp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:srcCompat="@drawable/ic_help_outline"
            app:tint="@color/cellular_text_primary"
            android:contentDescription="@string/cellular_help" />

        <TextView
            android:id="@+id/tvCarrierName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="--"
            android:textSize="@dimen/cellular_text_toolbar_carrier"
            android:textStyle="bold"
            android:textColor="@color/cellular_text_primary" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:srcCompat="@drawable/ic_settings"
            app:tint="@color/cellular_text_primary"
            android:contentDescription="@string/cellular_settings" />

    </LinearLayout>

    <!-- ── Scrollable content ──────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="65dp"
        android:clipToPadding="true"
        android:background="@color/cellular_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- ── Connection section ───────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cellular_section_connection"
                android:textSize="@dimen/cellular_text_section"
                android:textStyle="bold"
                android:textColor="@color/cellular_text_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="6dp" />

            <!-- Connection info rows (built programmatically) -->
            <LinearLayout
                android:id="@+id/connectionGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <!-- ── Empty / loading state ────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="48dp"
                android:paddingBottom="48dp"
                android:visibility="gone">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/cellular_badge_primary" />

                <TextView
                    android:id="@+id/tvEmptyMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/cellular_scanning"
                    android:textSize="@dimen/cellular_text_empty"
                    android:textColor="@color/cellular_text_label"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Cell detail cards (no extra section title — matches reference) -->

            <!-- Cell cards (built programmatically) -->
            <LinearLayout
                android:id="@+id/cellsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
