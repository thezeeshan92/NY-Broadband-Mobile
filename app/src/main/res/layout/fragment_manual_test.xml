<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/test_manual_title"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:titleTextColor="?attr/colorOnSurface" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_margin">

            <!-- Heading -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/test_manual_title"
                android:textSize="@dimen/text_headline_medium"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/test_manual_subtitle"
                android:textSize="@dimen/text_body"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:lineSpacingMultiplier="1.4" />

            <!-- ── Duration card ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:background="?attr/colorSurfaceVariant"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/test_duration_label"
                    android:textSize="@dimen/text_label"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.06" />

                <TextView
                    android:id="@+id/tvDurationValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="10 seconds"
                    android:textSize="@dimen/text_body"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:valueFrom="7"
                    android:valueTo="15"
                    android:stepSize="1"
                    android:value="10"
                    app:trackColorActive="?attr/colorPrimary"
                    app:thumbColor="?attr/colorPrimary"
                    app:trackColorInactive="?attr/colorOutlineVariant" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="7s"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15s"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDataEstimate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/test_data_estimate_default"
                    android:textSize="@dimen/text_body_small"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- ── Server card ───────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="?attr/colorSurfaceVariant"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/test_server_label"
                    android:textSize="@dimen/text_label"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.06" />

                <TextView
                    android:id="@+id/tvServerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/test_server_auto"
                    android:textSize="@dimen/text_body"
                    android:textColor="?attr/colorOnSurface"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tvServerRegion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/test_server_region_auto"
                    android:textSize="@dimen/text_body_small"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <!-- ── Current signal card ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="?attr/colorSurfaceVariant"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/test_current_signal_label"
                    android:textSize="@dimen/text_label"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.06" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvSignalTier"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="--"
                        android:textSize="@dimen/text_body"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/tvSignalNetwork"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="@dimen/text_body_small"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Bottom action bar ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_margin"
        android:paddingBottom="24dp"
        android:background="?attr/colorSurface">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartTest"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_large"
            android:text="@string/test_start_btn"
            android:textSize="15sp"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

</LinearLayout>
