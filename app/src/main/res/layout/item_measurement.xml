<?xml version="1.0" encoding="utf-8"?>
<!--
    RecyclerView row for a single MeasurementEntity in the Results list.
    TODO: wire to MeasurementAdapter in a future iteration.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/screen_margin"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="0dp"
    app:cardBackgroundColor="?attr/colorSurfaceVariant"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/card_padding">

        <!-- Signal tier color dot -->
        <View
            android:id="@+id/signalDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_signal_dot" />

        <!-- Text content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSignalQuality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                tools:text="Good" />

            <TextView
                android:id="@+id/tvNetworkInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="4G LTE · Verizon" />

            <!-- Speed summary — only visible for speed test rows -->
            <TextView
                android:id="@+id/tvSpeedSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:textColor="?attr/colorPrimary"
                android:visibility="gone"
                tools:text="↓ 23.4  ↑ 8.1 Mbps" />

        </LinearLayout>

        <!-- Timestamp + sync status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="3:42 PM" />

            <!-- Only visible for PENDING or FAILED — hidden for UPLOADED -->
            <TextView
                android:id="@+id/tvSyncStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"
                tools:text="Waiting to upload" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
