<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_grid_cell_sheet"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <View
            android:layout_width="@dimen/drag_handle_width"
            android:layout_height="@dimen/drag_handle_height"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/drag_handle_margin_top"
            android:layout_marginBottom="@dimen/drag_handle_margin_bottom"
            android:background="@drawable/bg_drag_handle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_place_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="@dimen/text_headline_large"
                android:textStyle="bold"
                tools:text="Lake Creek, TX" />

            <ImageButton
                android:id="@+id/btn_expand_toggle"
                android:layout_width="@dimen/min_touch_target"
                android:layout_height="@dimen/min_touch_target"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/map_grid_cell_expand"
                android:padding="12dp"
                android:src="@drawable/ic_expand_more_18" />

            <ImageButton
                android:id="@+id/btn_close"
                android:layout_width="@dimen/min_touch_target"
                android:layout_height="@dimen/min_touch_target"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@android:string/cancel"
                android:padding="12dp"
                android:src="@drawable/ic_close" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chip_carrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_grid_cell_chip_circle"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/white"
                android:textSize="@dimen/text_body_small"
                app:drawableStartCompat="@drawable/ic_cellular"
                tools:text="All" />

            <TextView
                android:id="@+id/chip_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_grid_cell_chip_circle"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/white"
                android:textSize="@dimen/text_body_small"
                app:drawableStartCompat="@drawable/ic_schedule_24"
                tools:text="3/7/2026" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_fastest_dl_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_metric"
                        android:textStyle="bold"
                        tools:text="1,006" />

                    <TextView
                        android:id="@+id/tv_fastest_dl_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/map_grid_cell_mbps_unit"
                        android:textColor="#B0B0B0"
                        android:textSize="@dimen/text_body_small" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/bar_dl_track"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_metric_bar_track">

                    <View
                        android:id="@+id/bar_dl_fill"
                        android:layout_width="80dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_metric_bar_fill_good" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/map_grid_cell_fastest_download"
                    android:textColor="#E0E0E0"
                    android:textSize="@dimen/text_label" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_fastest_ul_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_metric"
                        android:textStyle="bold"
                        tools:text="131" />

                    <TextView
                        android:id="@+id/tv_fastest_ul_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/map_grid_cell_mbps_unit"
                        android:textColor="#B0B0B0"
                        android:textSize="@dimen/text_body_small" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/bar_ul_track"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_metric_bar_track">

                    <View
                        android:id="@+id/bar_ul_fill"
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_metric_bar_fill_good" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/map_grid_cell_fastest_upload"
                    android:textColor="#E0E0E0"
                    android:textSize="@dimen/text_label" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/map_grid_cell_square_summary"
            android:textColor="@color/white"
            android:textSize="@dimen/text_title"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_grid_cell_chip_circle"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#9CA3AF"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/map_grid_cell_col_download"
                    android:textColor="#9CA3AF"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/map_grid_cell_col_upload"
                    android:textColor="#9CA3AF"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/map_grid_cell_col_latency"
                    android:textColor="#9CA3AF"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="4">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/map_grid_cell_row_fastest"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body_small" />

                <TextView
                    android:id="@+id/pill_fast_dl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_grid_pill_pink"
                    android:gravity="center"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption"
                    tools:text="1,006 mbps" />

                <TextView
                    android:id="@+id/pill_fast_ul"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_grid_pill_pink"
                    android:gravity="center"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption"
                    tools:text="131 mbps" />

                <TextView
                    android:id="@+id/pill_fast_lat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_grid_pill_pink"
                    android:gravity="center"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption"
                    tools:text="14 ms" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="4">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/map_grid_cell_row_average"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body_small" />

                <TextView
                    android:id="@+id/pill_avg_dl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_grid_pill_muted"
                    android:gravity="center"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption"
                    tools:text="145 mbps" />

                <TextView
                    android:id="@+id/pill_avg_ul"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_grid_pill_muted"
                    android:gravity="center"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption"
                    tools:text="16.8 mbps" />

                <TextView
                    android:id="@+id/pill_avg_lat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_grid_pill_muted"
                    android:gravity="center"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption"
                    tools:text="151 ms" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="4">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/map_grid_cell_row_slowest"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body_small" />

                <TextView
                    android:id="@+id/pill_slow_dl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_grid_pill_blue"
                    android:gravity="center"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption"
                    tools:text="0 mbps" />

                <TextView
                    android:id="@+id/pill_slow_ul"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_grid_pill_blue"
                    android:gravity="center"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption"
                    tools:text="0 mbps" />

                <TextView
                    android:id="@+id/pill_slow_lat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_grid_pill_pink"
                    android:gravity="center"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption"
                    tools:text="1,550 ms" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/map_grid_cell_compare_carriers"
            android:textColor="#9CA3AF"
            android:textSize="@dimen/text_caption" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_grid_cell_chip_circle"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/map_grid_cell_chart_avg_download"
                android:textColor="@color/white"
                android:textSize="@dimen/text_body_small" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="@string/map_carrier_att"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption" />

                <FrameLayout
                    android:id="@+id/chart_track_att"
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_bar_track">

                    <View
                        android:id="@+id/chart_bar_att"
                        android:layout_width="40dp"
                        android:layout_height="match_parent"
                        android:background="#3B82F6" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="@string/map_carrier_tmobile"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption" />

                <FrameLayout
                    android:id="@+id/chart_track_tmo"
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_bar_track">

                    <View
                        android:id="@+id/chart_bar_tmo"
                        android:layout_width="120dp"
                        android:layout_height="match_parent"
                        android:background="#EC4899" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="@string/map_carrier_verizon"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption" />

                <FrameLayout
                    android:id="@+id/chart_track_vzw"
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_bar_track">

                    <View
                        android:id="@+id/chart_bar_vzw"
                        android:layout_width="16dp"
                        android:layout_height="match_parent"
                        android:background="#EF4444" />
                </FrameLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="end"
                android:text="@string/map_grid_cell_chart_scale"
                android:textColor="#6B7280"
                android:textSize="10sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_grid_cell_chip_outline"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/map_grid_cell_chip_best"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_grid_cell_chip_selected"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/map_filter_map_average"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_grid_cell_chip_outline"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/map_grid_cell_chip_worst"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_grid_cell_chip_selected"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/map_filter_map_download"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_grid_cell_chip_outline"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/map_filter_map_upload"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_grid_cell_chip_outline"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/map_filter_map_latency"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/map_grid_cell_promoted_plans"
            android:textColor="#6B7280"
            android:textSize="@dimen/text_caption" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#14532D"
            android:padding="12dp"
            android:text="@string/map_grid_cell_promo_placeholder"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body_small" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1E3A5F"
            android:padding="12dp"
            android:text="@string/map_grid_cell_promo_placeholder"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body_small" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_grid_cell_chip_circle"
            android:orientation="vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/action_directions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:minHeight="@dimen/min_touch_target"
                android:padding="12dp"
                android:text="@string/map_grid_cell_action_directions"
                android:textColor="@color/white"
                android:textSize="@dimen/text_body"
                app:drawableStartCompat="@drawable/ic_public_24" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3A3A3C" />

            <TextView
                android:id="@+id/action_copy_link"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:minHeight="@dimen/min_touch_target"
                android:padding="12dp"
                android:text="@string/map_grid_cell_action_copy_link"
                android:textColor="@color/white"
                android:textSize="@dimen/text_body"
                app:drawableStartCompat="@drawable/ic_link_24" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
