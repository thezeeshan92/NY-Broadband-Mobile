<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:titleTextColor="?attr/colorOnSurface" />

    <TextView
        android:id="@+id/tvStep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/screen_margin"
        android:paddingEnd="@dimen/screen_margin"
        android:paddingBottom="4dp"
        android:textSize="@dimen/text_label"
        android:textColor="?attr/colorPrimary"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.06"
        android:text="Step 2" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_margin"
            android:paddingTop="16dp">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@android:drawable/ic_menu_directions"
                android:padding="24dp"
                android:background="@drawable/bg_icon_circle"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/perm_background_title"
                android:textSize="@dimen/text_headline_medium"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:lineSpacingMultiplier="1.2" />

            <!--
                Body text swapped in code:
                  API 29: shows standard dialog text.
                  API 30+: shows Settings-redirect text (no dialog available).
            -->
            <TextView
                android:id="@+id/tvBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/perm_background_body"
                android:textSize="@dimen/text_body"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:lineSpacingMultiplier="1.4" />

            <!-- API 30+ note — shown only when dialog won't appear -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/settingsNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/ny_blue_100"
                app:strokeWidth="0dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/card_padding"
                    android:text="@string/perm_background_settings_note"
                    android:textSize="@dimen/text_body_small"
                    android:textColor="@color/ny_blue_900"
                    android:lineSpacingMultiplier="1.3" />

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:background="?attr/colorSurfaceVariant"
                android:padding="@dimen/card_padding"
                android:backgroundTint="?attr/colorSurfaceVariant">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_background_bullet_why"
                    android:textSize="@dimen/text_body_small"
                    android:textColor="@color/signal_good"
                    android:lineSpacingMultiplier="1.3" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/perm_background_bullet_battery"
                    android:textSize="@dimen/text_body_small"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky button area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_margin"
        android:paddingBottom="24dp">

        <!--
            API 29: label = "Allow Background Access" — launches permission dialog.
            API 30+: label = "Open Location Settings" — opens system Settings directly.
            Text is set in code.
        -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAllow"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_large"
            android:text="@string/perm_background_allow"
            android:textSize="15sp"
            style="@style/Widget.Material3.Button" />

        <TextView
            android:id="@+id/tvSkip"
            android:layout_width="match_parent"
            android:layout_height="@dimen/min_touch_target"
            android:gravity="center"
            android:text="@string/perm_background_skip"
            android:textSize="@dimen/text_body_small"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

</LinearLayout>
