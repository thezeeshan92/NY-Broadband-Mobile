<?xml version="1.0" encoding="utf-8"?>
<!--
    Settings bottom sheet for the Cellular screen.
    Matches the CoverageMap.com "Cellular Info Settings" dialog.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Drag handle -->
    <View
        android:layout_width="@dimen/drag_handle_width"
        android:layout_height="@dimen/drag_handle_height"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/drag_handle_margin_top"
        android:layout_marginBottom="@dimen/drag_handle_margin_bottom"
        android:background="@drawable/bg_drag_handle" />

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_margin"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cellular_settings_title"
            android:textSize="@dimen/text_headline_medium"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="@string/action_close" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="@dimen/screen_margin"
        android:layout_marginEnd="@dimen/screen_margin"
        android:background="?attr/colorOutlineVariant" />

    <!-- ── Advanced View toggle ──────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/screen_margin"
        android:minHeight="@dimen/min_touch_target">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cellular_setting_advanced_view"
            android:textSize="@dimen/text_body"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchAdvancedView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="@dimen/screen_margin"
        android:layout_marginEnd="@dimen/screen_margin"
        android:background="?attr/colorOutlineVariant" />

    <!-- ── Hide Neighbor Cells toggle ───────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/screen_margin"
        android:minHeight="@dimen/min_touch_target">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cellular_setting_hide_neighbors"
            android:textSize="@dimen/text_body"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchHideNeighbors"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="@dimen/screen_margin"
        android:layout_marginEnd="@dimen/screen_margin"
        android:background="?attr/colorOutlineVariant" />

    <!-- ── Refresh Frequency slider ──────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_margin"
        android:paddingEnd="@dimen/screen_margin"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/cellular_setting_refresh_freq"
                android:textSize="@dimen/text_body"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tvRefreshValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 Seconds"
                android:textSize="@dimen/text_body"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold" />

        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderRefreshFreq"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="1"
            android:valueTo="60"
            android:stepSize="1"
            android:value="7" />

    </LinearLayout>

    <!-- Bottom safe-area padding -->
    <View
        android:layout_width="match_parent"
        android:layout_height="24dp" />

</LinearLayout>
