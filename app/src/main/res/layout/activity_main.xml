<?xml version="1.0" encoding="utf-8"?>
<!--
    Root layout: CoordinatorLayout so the BottomNavigationView can float over
    the NavHostFragment. HomeMapFragment's MapView bleeds behind the bottom nav —
    we use android:fitsSystemWindows="false" on the fragment container intentionally.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <!-- NavHost: fills entire screen, sits behind the bottom nav in z-order -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navHostFragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <!--
        BottomNavigationView: anchored to the bottom.
        On the Home (map) tab its background becomes transparent so the map
        extends underneath — handled in HomeMapFragment.onResume / onPause.
    -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?attr/colorSurface"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/selector_nav_icon"
        app:itemTextColor="@color/selector_nav_icon"
        app:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
