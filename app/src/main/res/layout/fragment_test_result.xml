<?xml version="1.0" encoding="utf-8"?><!--
    Test Result Detail Screen
    ─────────────────────────────────────────────────────────────────────
    View IDs are kept in strict sync with TestResultFragment.kt.
    If you rename an ID here, update the Fragment too.

    contentGroup:   LinearLayout wrapping everything below the toolbar.
                    Hidden during Loading state. Shown with for NotFound.
    tierBadgeCard:  MaterialCardView — background tinted by signal tier color
                    in code via setCardBackgroundColor().
    layoutAdvanced: Collapsed by default. Shown when tvAdvancedToggle is tapped.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/test_result_title"
        app:titleTextColor="?attr/colorOnSurface" />

    <!-- contentGroup: hidden during Loading, shown for NotFound + Ready -->
    <LinearLayout
        android:id="@+id/contentGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/screen_margin">

                <!-- ── Tier badge card ────────────────────────────────────── -->
                <!--
                    Background set in code: tierBadgeCard.setCardBackgroundColor(tierColor).
                    Text stays white — readable on all tier colors (green/amber/orange/red/grey).
                -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tierBadgeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <!-- e.g. "Good", "Fair", "No service" -->
                        <TextView
                            android:id="@+id/tvTierBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@android:color/white"
                            android:textSize="32sp"
                            android:textStyle="bold" />

                        <!-- e.g. "Speed test · 4G LTE" or "Passive reading" -->
                        <TextView
                            android:id="@+id/tvTierSubLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="--"
                            android:textColor="#CCFFFFFF"
                            android:textSize="@dimen/text_body_small" />

                        <!-- Shown only when result came from PlaceholderSpeedTestEngine -->
                        <com.google.android.material.chip.Chip
                            android:id="@+id/tvPlaceholderBadge"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/result_placeholder_badge"
                            android:textSize="10sp"
                            android:visibility="gone"
                            app:chipBackgroundColor="@color/signal_weak" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Speed cards row ────────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <!-- Download -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/colorSurfaceVariant"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvDownloadSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_metric"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/result_download_label"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body_small" />

                    </LinearLayout>

                    <View
                        android:layout_width="8dp"
                        android:layout_height="0dp" />

                    <!-- Upload -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/colorSurfaceVariant"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvUploadSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_metric"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/result_upload_label"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body_small" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Primary detail rows ────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="?attr/colorSurfaceVariant"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- Latency -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/test_result_row_latency"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body" />

                        <TextView
                            android:id="@+id/tvLatencyValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Jitter -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/test_result_row_jitter"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body" />

                        <TextView
                            android:id="@+id/tvJitterValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Network -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/test_result_row_network"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body" />

                        <TextView
                            android:id="@+id/tvNetworkType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Carrier -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/test_result_row_carrier"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body" />

                        <TextView
                            android:id="@+id/tvCarrierName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Server -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/test_result_row_server"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body" />

                        <TextView
                            android:id="@+id/tvServerName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Duration -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/test_result_row_duration"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body" />

                        <TextView
                            android:id="@+id/tvDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Measured at -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/test_result_row_time"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body" />

                        <TextView
                            android:id="@+id/tvTimestamp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Upload sync note — only shown if PENDING or FAILED -->
                <TextView
                    android:id="@+id/tvSyncStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="@dimen/text_body_small"
                    android:visibility="gone" />

                <!-- ── Technical details (collapsed) ──────────────────────── -->
                <!--
                    Plain-language toggle. Tap to expand/collapse raw diagnostic data.
                    Intended for power users and support — hidden by default.
                -->
                <TextView
                    android:id="@+id/tvAdvancedToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="@string/result_advanced_show"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="@dimen/text_body_small" />

                <LinearLayout
                    android:id="@+id/layoutAdvanced"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="?attr/colorSurfaceVariant"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding"
                    android:visibility="gone">

                    <!-- RSRP -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/result_adv_rsrp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body_small" />

                        <TextView
                            android:id="@+id/tvRsrp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body_small" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Signal bars -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/result_adv_signal_bars"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body_small" />

                        <TextView
                            android:id="@+id/tvSignalBars"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body_small" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- GPS accuracy -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/result_adv_gps_accuracy"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body_small" />

                        <TextView
                            android:id="@+id/tvGpsAccuracy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body_small" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Device -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/result_adv_device"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body_small" />

                        <TextView
                            android:id="@+id/tvDevice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body_small" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- App version -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/result_adv_app_version"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body_small" />

                        <TextView
                            android:id="@+id/tvAppVersion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body_small" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Session ID -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/result_adv_session_id"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body_small" />

                        <TextView
                            android:id="@+id/tvSessionId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="middle"
                            android:maxLines="1"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body_small" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── Bottom action bar ──────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:orientation="vertical"
            android:padding="@dimen/screen_margin"
            android:paddingBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDone"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_large"
                android:text="@string/test_btn_done"
                android:textSize="15sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
