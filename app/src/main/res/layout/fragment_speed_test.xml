<?xml version="1.0" encoding="utf-8"?>
<!--
    Speed Test tab — CoverageMap.com–style launcher screen.
    Dark background, large gradient "Start Test" circle, context tabs, location row.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E0E1A"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- ── TOP SECTION: carrier info + big circle button ─────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="24dp">

        <!-- Carrier / ISP name -->
        <TextView
            android:id="@+id/tvCarrierName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="Verizon Wireless" />

        <!-- Device + connection type row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivConnectionIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_wifi_24"
                app:tint="#9CA3AF" />

            <TextView
                android:id="@+id/tvDeviceInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                tools:text="Pixel 7 · Wi-Fi" />
        </LinearLayout>

        <!-- ── CENTER: big gradient circle ───────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center">

            <!-- Outer glow ring -->
            <View
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:alpha="0.18"
                android:background="@drawable/bg_start_test_gradient" />

            <!-- Tappable Start Test button -->
            <TextView
                android:id="@+id/btnStartTest"
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_start_test_gradient"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/speed_start_test"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Run Multiple Tests pill -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRunMultiple"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/speed_run_multiple"
            android:textColor="#CCCCCC"
            app:strokeColor="#44FFFFFF" />

    </LinearLayout>

    <!-- ── BOTTOM SECTION: icons, tabs, location ─────────────────────────── -->
    <!-- paddingBottom=64dp accounts for the BottomNavigationView (56dp) + gap -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="90dp">

        <!-- Gear icon (left) + Signal icon (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/btnSpeedSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/settings_title"
                android:padding="10dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/white" />

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnSignalInfo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/cellular_section_connection"
                android:padding="10dp"
                android:src="@drawable/ic_cellular"
                app:tint="@color/white" />

        </LinearLayout>

        <!-- Context tabs: Indoors | Outdoors | Driving | Other -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tabIndoors"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_speed_context_tab_selected"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/speed_context_indoors"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabOutdoors"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_speed_context_tab_unselected"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/speed_context_outdoors"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tabDriving"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_speed_context_tab_unselected"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/speed_context_driving"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tabOther"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_speed_context_tab_unselected"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/speed_context_other"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Location row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_speed_dark_surface"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="@null"
                android:src="@drawable/flag_us_badge" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLocationName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/speed_location_default"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLocationSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/speed_location_sub"
                    android:textColor="#7777AA"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvLocationChange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/speed_location_change"
                android:textColor="#4FC3F7"
                android:textSize="13sp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:rotation="180"
                android:src="@drawable/ic_arrow_back"
                app:tint="#4FC3F7" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>