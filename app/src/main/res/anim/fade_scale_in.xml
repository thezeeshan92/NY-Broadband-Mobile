<?xml version="1.0" encoding="utf-8"?>
<!--
    Enter animation for the Test Result screen.
    Combines a subtle scale-up (96% → 100%) with a fade-in so the result
    screen feels like it's "revealing" rather than abruptly replacing the test.
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:interpolator/decelerate_quint">

    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:duration="360" />

    <scale
        android:fromXScale="0.96"
        android:toXScale="1.0"
        android:fromYScale="0.96"
        android:toYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%"
        android:duration="360" />

</set>
