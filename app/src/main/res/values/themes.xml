<?xml version="1.0" encoding="utf-8"?>
<!--
    App is dark-only. Parent is Material3.Dark — light mode is never used.
    values-night/themes.xml mirrors this file so system dark-mode toggle has no effect.
-->
<resources>

    <style name="Theme.NYBroadband" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Brand primary: purple accent on dark -->
        <item name="colorPrimary">@color/ds_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/ds_surface_2</item>
        <item name="colorOnPrimaryContainer">@color/ds_accent</item>

        <item name="colorSecondary">@color/ds_accent_blue</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surfaces — deep dark -->
        <item name="colorSurface">@color/ds_surface_1</item>
        <item name="colorOnSurface">@color/ds_text_primary</item>
        <item name="colorSurfaceVariant">@color/ds_surface_2</item>
        <item name="colorOnSurfaceVariant">@color/ds_text_secondary</item>
        <item name="colorOutline">@color/ds_divider</item>
        <item name="colorOutlineVariant">@color/ds_divider</item>

        <!-- Error -->
        <item name="colorError">@color/ds_error</item>
        <item name="colorOnError">@color/white</item>

        <!-- System bars — fully dark, no light icons -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/ds_bg</item>
    </style>

    <!-- Full-screen dialog (ManualTestFragment) -->
    <style name="Theme.NYBroadband.FullScreenDialog" parent="Theme.NYBroadband">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

    <!-- Test Settings bottom sheet -->
    <style name="ThemeOverlay.TestSettingsBottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <!-- Grid cell detail sheet -->
    <style name="ThemeOverlay.GridCellBottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash -->
    <style name="Theme.NYBroadband.Splash" parent="Theme.NYBroadband">
        <item name="android:windowBackground">@color/ds_bg</item>
        <item name="android:statusBarColor">@color/ds_bg</item>
        <item name="android:navigationBarColor">@color/ds_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>
