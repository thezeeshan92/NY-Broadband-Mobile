    <!-- ── Welcome screen ── -->
    <string name="onboarding_welcome_title">Help map New York\'s broadband</string>
    <string name="onboarding_welcome_body">NY Broadband Mobile crowdsources mobile coverage
        data across New York State. Every measurement you collect helps identify gaps
        in connectivity for rural and underserved communities.</string>
    <string name="onboarding_welcome_cta">Get Started</string>

    <!-- ── Sign in / Guest decision ── -->
    <string name="onboarding_signin_title">Who\'s mapping today?</string>
    <string name="onboarding_signin_body">Sign in to back up your data and access it across
        devices. Or continue as a guest — your measurements stay on this phone until
        you decide to create an account.</string>
    <string name="onboarding_signin_google">Sign in with Google</string>
    <string name="onboarding_signin_guest">Continue as Guest</string>
    <string name="onboarding_signin_terms">By continuing, you agree to the NY Broadband
        privacy policy. Location data is used only for coverage mapping.</string>

    <!-- ── Permission: Foreground Location ──
         READ BY A NON-TECHNICAL COMMUNITY MEMBER.
         Plain language — no jargon.                                          -->
    <string name="perm_location_title">Your location powers the map</string>
    <string name="perm_location_body">NY Broadband needs to know where you are to record
        signal measurements on the map. Without location access, we can\'t show you
        or others where the coverage gaps are.</string>
    <!-- Bullet: what this permission IS used for -->
    <string name="perm_location_bullet_uses">✓  Tags signal readings to your location on the coverage map</string>
    <!-- Bullets: what it is NOT used for -->
    <string name="perm_location_bullet_no_share">✗  Your location is never sold or shared with advertisers</string>
    <string name="perm_location_bullet_no_ads">✗  Not used for any advertising or tracking purpose</string>
    <string name="perm_location_allow">Allow Location Access</string>

    <!-- ── Permission: Background Location ──
         Two versions — one for API 29, one for API 30+ (Settings-only path).  -->
    <string name="perm_background_title">Keep measuring as you travel</string>
    <!-- API 29: system dialog still available -->
    <string name="perm_background_body">To collect signal data even with the screen off
        or when you switch to another app, allow NY Broadband to access your location
        in the background. This makes the coverage map accurate during drives and
        commutes — the most useful measurement windows.</string>
    <!-- API 30+: dialog no longer shown by Android; must use Settings -->
    <string name="perm_background_body_v30">To collect signal data while the screen is off,
        NY Broadband needs background location access. Tap the button below and then
        choose \"Allow all the time\" on the next screen.</string>
    <!-- Blue info card shown only on API 30+ -->
    <string name="perm_background_settings_note">Android will open your Location permission
        settings. Look for \"NY Broadband\" and change it to \"Allow all the time\".</string>
    <!-- Button labels (set in code based on API level) -->
    <string name="perm_background_allow">Allow Background Access</string>
    <string name="perm_background_open_settings">Open Location Settings</string>
    <string name="perm_background_skip">Skip — I\'ll measure manually</string>
    <!-- Bullets -->
    <string name="perm_background_bullet_why">✓  Enables passive signal collection while you drive or walk</string>
    <string name="perm_background_bullet_battery">✓  Designed to use minimal battery — reads signal, not continuous GPS</string>

    <!-- ── Permission: READ_PHONE_STATE ──
         Explain what signal data means without using technical terms.         -->
    <string name="perm_phone_state_title">Read your network signal</string>
    <string name="perm_phone_state_body">NY Broadband reads your phone\'s signal strength
        and network type — for example, whether you\'re on 4G LTE or 5G, and how
        strong the connection is. This is the actual coverage data that gets recorded
        on the map.</string>
    <!-- Bullets -->
    <string name="perm_phone_state_bullet_reads">✓  Reads signal strength (bars) and network type (4G / 5G)</string>
    <string name="perm_phone_state_bullet_no_calls">✗  Does not access calls, messages, or your contacts</string>
    <string name="perm_phone_state_bullet_no_monitor">✗  Does not track or record call activity</string>
    <string name="perm_phone_state_allow">Allow Signal Reading</string>

    <!-- ── Permission: POST_NOTIFICATIONS (API 33+ only) ──
         Explain why a background service needs to show a notification.       -->
    <string name="perm_notifications_title">Know when it\'s running</string>
    <string name="perm_notifications_body">When NY Broadband is quietly collecting signal
        data in the background, Android requires a small notification so you can always
        see it and turn it off. You\'ll only ever get one notification from this app —
        no alerts, no messages.</string>
    <!-- Bullets -->
    <string name="perm_notifications_bullet_status">✓  Shows one small status notification when background collection is active</string>
    <string name="perm_notifications_bullet_no_marketing">✗  No alerts, reminders, or promotional messages — ever</string>
    <string name="perm_notifications_allow">Allow Notifications</string>
    <string name="perm_notifications_skip">Skip for now</string>

    <!-- Shared "Skip" label used on location and phone state screens -->
    <string name="perm_skip">Not now — I\'ll decide later</string>

