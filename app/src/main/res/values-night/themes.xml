<?xml version="1.0" encoding="utf-8"?>
<!--
    Night override — identical to values/themes.xml.
    App is dark-only; this file ensures system dark-mode toggle has no visual effect.
-->
<resources>

    <style name="Theme.NYBroadband" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/ds_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/ds_surface_2</item>
        <item name="colorOnPrimaryContainer">@color/ds_accent</item>

        <item name="colorSecondary">@color/ds_accent_blue</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSurface">@color/ds_surface_1</item>
        <item name="colorOnSurface">@color/ds_text_primary</item>
        <item name="colorSurfaceVariant">@color/ds_surface_2</item>
        <item name="colorOnSurfaceVariant">@color/ds_text_secondary</item>
        <item name="colorOutline">@color/ds_divider</item>
        <item name="colorOutlineVariant">@color/ds_divider</item>

        <item name="colorError">@color/ds_error</item>
        <item name="colorOnError">@color/white</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/ds_bg</item>
    </style>

    <style name="Theme.NYBroadband.Splash" parent="Theme.NYBroadband">
        <item name="android:windowBackground">@color/ds_bg</item>
        <item name="android:statusBarColor">@color/ds_bg</item>
        <item name="android:navigationBarColor">@color/ds_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>
